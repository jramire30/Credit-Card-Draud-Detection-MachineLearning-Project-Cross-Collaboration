    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "sim_df = pd.read_csv(\"fraud_dashboard_simulation_100000rows_enhanced.csv\")\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "def generate_recurrence(row):\n",
    "    prob = row[\"fraud_probability_pct\"] / 100\n",
    "    \n",
    "    if prob >= 0.90:  # High risk\n",
    "        return np.random.choice([1, 2, 3, 4], p=[0.3, 0.3, 0.25, 0.15])\n",
    "    elif prob >= 0.50:  # Medium risk\n",
    "        return np.random.choice([0, 1, 2], p=[0.6, 0.3, 0.1])\n",
    "    else:  # Low risk\n",
    "        return np.random.choice([0, 1], p=[0.9, 0.1])\n",
    "\n",
    "sim_df[\"flag_recurrence\"] = sim_df.apply(generate_recurrence, axis=1)\n",
    "\n",
    "sim_df.to_csv(\n",
    "    \"fraud_dashboard_simulation_100000rows_enhanced_with_recurrence.csv\",\n",
    "    index=False\n",
    ")\n",
    "\n",
    "sim_df.head()"
