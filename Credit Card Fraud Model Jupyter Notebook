    "total_seconds = int((end - start).total_seconds())\n",
    "\n",
    "random_seconds = np.random.randint(0, total_seconds, size=len(df))\n",
    "\n",
    "df[\"transaction_datetime\"] = start + pd.to_timedelta(random_seconds, unit=\"s\")\n",
    "\n",
    "df[\"transaction_date\"] = df[\"transaction_datetime\"].dt.date\n",
    "df[\"transaction_hour\"] = df[\"transaction_datetime\"].dt.hour\n",
