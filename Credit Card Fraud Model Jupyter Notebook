    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "N_SIM = 5000\n",
    "SEED = 42\n",
    "\n",
    "HIGH_T = 0.90 \n",
    "MED_T  = 0.50\n",
    "\n",
    "sim_df = df.sample(n=N_SIM, replace=True, random_state=SEED).copy()\n",
    "\n",
    "rng = np.random.default_rng(SEED)\n",
    "start = pd.to_datetime(\"2013-09-01 00:00:00\")\n",
    "end   = pd.to_datetime(\"2013-09-30 23:59:59\")\n",
    "total_seconds = int((end - start).total_seconds())\n",
    "\n",
    "sim_seconds = rng.integers(0, total_seconds, size=len(sim_df))\n",
    "sim_df[\"transaction_datetime\"] = start + pd.to_timedelta(sim_seconds, unit=\"s\")\n",
    "sim_df[\"transaction_date\"] = sim_df[\"transaction_datetime\"].dt.date\n",
    "\n",
    "X_sim = sim_df.drop(columns=[\"Class\"], errors=\"ignore\")\n",
    "X_sim = X_sim[feature_cols].copy()\n",
    "\n",
    "sim_proba = rf_model.predict_proba(X_sim)[:, 1]\n",
    "sim_df[\"fraud_probability_pct\"] = (sim_proba * 100).round(2)\n",
    "\n",
    "def assign_band(p):\n",
    "    if p >= HIGH_T:\n",
    "        return \"High\"\n",
    "    elif p >= MED_T:\n",
    "        return \"Medium\"\n",
    "    else:\n",
    "        return \"Low\"\n",
    "\n",
    "sim_df[\"risk_band\"] = sim_proba\n",
    "sim_df[\"risk_band\"] = sim_df[\"risk_band\"].apply(assign_band)\n",
    "\n",
    "action_map = {\"High\": \"Auto-Freeze\", \"Medium\": \"Human Review\", \"Low\": \"Allow\"}\n",
    "sim_df[\"recommended_action\"] = sim_df[\"risk_band\"].map(action_map)\n",
    "\n",
    "sim_export = sim_df[[\n",
    "    \"Time\",\n",
    "    \"Amount\",\n",
    "    \"fraud_probability_pct\",\n",
    "    \"risk_band\",\n",
    "    \"recommended_action\",\n",
    "    \"transaction_date\"\n",
    "]].copy()\n",
    "\n",
    "sim_export.head()"
   ]
  },
