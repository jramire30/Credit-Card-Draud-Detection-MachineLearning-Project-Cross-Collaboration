    "thresholds = np.linspace(0.2, 0.99, 20)\n",
    "rows = []\n",
    "\n",
    "for t in thresholds:\n",
    "    preds = (rf_proba >= t).astype(int)\n",
    "\n",
    "    p = precision_score(y_test, preds, zero_division=0)\n",
    "    r = recall_score(y_test, preds, zero_division=0)\n",
    "    flagged_rate = preds.mean()\n",
    "\n",
    "    rows.append([t, p, r, flagged_rate])\n",
    "\n",
    "threshold_df = pd.DataFrame(rows, columns=[\"threshold\", \"precision\", \"recall\", \"flagged_rate\"])\n",
    "threshold_df"
